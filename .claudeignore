# Keep AI-agent context lean: everything here is either generated, vendored,
# or binary — never worth reading into a session. Source of truth for app
# code is src/ and server/src/; for build docs, docs/ + CLAUDE.md.

# Vendored dependencies (849M + 171M)
node_modules/
server/node_modules/

# Native project generated by `npx expo prebuild` / run:ios (1.2G) — config
# lives in app.json, not here
ios/
android/

# Build outputs and caches
dist/
.expo/
server/dist/
*.hbc

# Lockfiles (pin via package.json; the lockfile bodies are noise)
package-lock.json
server/package-lock.json

# Drizzle migration snapshots (the .sql files stay readable; meta/ is
# generated bookkeeping)
server/drizzle/meta/

# Binary assets and logs
assets/
*.log
*.png
*.jpg
*.zip
