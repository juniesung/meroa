# Public by design (EXPO_PUBLIC_ vars are baked into the client bundle) —
# never put secrets here. Real secrets live in server/.env only.
EXPO_PUBLIC_API_URL=http://localhost:8787

# RevenueCat's public SDK key — safe to bundle (it only authorizes purchase
# requests, same trust level as a Stripe publishable key). Use the Test
# Store key (test_…) until real App Store Connect/Play Console products
# exist; swap to the production appl_… key before store submission (a
# release build initialized with a test_ key deliberately crashes).
EXPO_PUBLIC_REVENUECAT_IOS_KEY=
