# Supabase Postgres connection.
# Dashboard → Connect → copy the "Session pooler" connection string (port 5432).
# Use this same session-pooler URL for both migrations and the running API server.
# The direct connection is IPv6-only on the free tier — avoid it unless your
# network has working IPv6. Only switch a given connection to the transaction
# pooler (port 6543) if that part of the API ever runs serverless, and set
# `prepare: false` on the postgres.js client when you do.
DATABASE_URL=postgresql://postgres.xxxxxxxxxxxx:PASSWORD@aws-0-region.pooler.supabase.com:5432/postgres

# Symmetric secret for signing access/refresh JWTs. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

PORT=8787
NODE_ENV=development

# Server-side only — never shipped in the app bundle (CLAUDE.md §3).
# Get a key at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
# Defaults to Haiku 4.5 for low-latency chat. Bump to claude-sonnet-5 or
# claude-opus-4-8 if conversation quality needs it — see CLAUDE.md discussion.
ANTHROPIC_MODEL=claude-haiku-4-5

# Fair-use daily message limits — override for local testing (e.g. set
# FREE_DAILY_MESSAGES=3 to exercise the 429 path quickly). Defaults: 50 / 1000.
# FREE_DAILY_MESSAGES=50
# PLUS_DAILY_MESSAGES=1000
