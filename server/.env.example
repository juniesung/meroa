# Supabase Postgres connection.
# Dashboard → Connect → copy the "Session pooler" connection string (port 5432).
# Use this same session-pooler URL for both migrations and the running API server.
# The direct connection is IPv6-only on the free tier — avoid it unless your
# network has working IPv6. Only switch a given connection to the transaction
# pooler (port 6543) if that part of the API ever runs serverless, and set
# `prepare: false` on the postgres.js client when you do.
DATABASE_URL=postgresql://postgres.xxxxxxxxxxxx:PASSWORD@aws-0-region.pooler.supabase.com:5432/postgres

# Symmetric secret for signing access/refresh JWTs. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

PORT=8787
NODE_ENV=development

# Server-side only — never shipped in the app bundle (CLAUDE.md §3).
# Get a key at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
# Defaults to Haiku 4.5 for low-latency chat. Bump to claude-sonnet-5 or
# claude-opus-4-8 if conversation quality needs it — see CLAUDE.md discussion.
ANTHROPIC_MODEL=claude-haiku-4-5

# Fair-use daily message limits — override for local testing (e.g. set
# FREE_DAILY_MESSAGES=3 to exercise the 429 path quickly). Defaults: 20 / 100.
# FREE_DAILY_MESSAGES=20
# PLUS_DAILY_MESSAGES=100

# Free-plan creation caps (Phase 7, lib/limits.ts) — same override pattern.
# FREE_DAILY_TASKS=2
# FREE_MAX_ACTIVE_GOALS=1

# RevenueCat (Phase 7 billing) — both optional; routes/billing.ts returns 503
# until they're set, so the server boots fine without them during early dev
# (use npm run dev:plan to flip a user's plan directly in the meantime).
# Secret key from the RevenueCat dashboard (Project settings → API keys).
REVENUECAT_SECRET_API_KEY=
# The exact Authorization header value you configure on the RevenueCat
# webhook (Integrations → Webhooks) — not a JWT, just a shared secret string.
REVENUECAT_WEBHOOK_SECRET=
# Must match the entitlement identifier created in the RevenueCat dashboard.
# REVENUECAT_ENTITLEMENT_ID=plus

# Optional — the server boots and runs fine without it, just without error
# reporting. Get the DSN from Sentry: create a project (Platform: Node) →
# Settings → Client Keys (DSN) → copy the value there.
SENTRY_DSN=

# --- Proactive re-engagement notifications ---------------------------------
# Shared secret guarding POST /internal/tick. UNSET = the whole notification
# tick is disabled (the route 404s), so no proactive pushes are ever sent —
# set it to a long random string and configure a Railway cron to POST the
# endpoint every ~15 min with `Authorization: Bearer <this>`.
# CRON_SECRET=
# Inactivity (days) before a user becomes a win-back candidate. Default 3.
# NOTIFY_WINBACK_AFTER_DAYS=3
# The proactive-message cap (on top of user-set task reminders). Defaults 1/4.
# NOTIFY_MAX_PER_DAY=1
# NOTIFY_MAX_PER_WEEK=4
